# Copy this file to .env and fill in values for local development.
# In production, set these as real environment variables — never commit .env.

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=django-insecure-replace-me-with-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Docker Compose default matches docker-compose.yml)
DATABASE_URL=postgres://heddle:heddle_dev@localhost:5432/heddle

# Email (console backend logs to stdout; switch to SMTP in production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=you@example.com
# EMAIL_HOST_PASSWORD=secret

# Production-only (ignored in development)
# SECURE_SSL_REDIRECT=True
# USE_SECURE_PROXY_SSL_HEADER=False
# CSRF_TRUSTED_ORIGINS=https://heddle.example.org
# SESSION_COOKIE_AGE=28800
# PASSWORD_RESET_TIMEOUT=3600
